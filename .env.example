# Copie este arquivo como .env e preencha seus valores
# NÃO faça commit do .env real no Git

# Chave de API (gerada no dashboard SolanaEasy)
SOLANAEASY_API_KEY=sk_test_sua_chave_aqui

# Rede Solana: devnet (desenvolvimento) ou mainnet-beta (produção)
SOLANAEASY_NETWORK=devnet

# URL base do backend de observabilidade
# Em produção: https://api.solanaeasy.dev
SOLANAEASY_BASE_URL=http://localhost:8000

# Timeout para requisições HTTP (em segundos)
SOLANAEASY_TIMEOUT=30
